# Tensa configuration — copy to `.env` and adjust. All values have working
# defaults in docker-compose.yml; everything here is optional.

# ── Worker scaling ───────────────────────────────────────────────────────────
# ARQ concurrency per worker process and per-job wall-clock ceiling (seconds).
# Scale horizontally with: docker compose up --scale worker=N
WORKER_MAX_JOBS=4
WORKER_JOB_TIMEOUT=600

# ── Disk safety ──────────────────────────────────────────────────────────────
# Hard ceiling on a single download, in yt-dlp size syntax (e.g. 4G, 500M).
MAX_DOWNLOAD_FILESIZE=4G

# ── YouTube hardening (other platforms need none of this) ────────────────────
# Netscape cookies.txt from a logged-in browser. Most impactful lever:
# authenticates, lifts rate limits, unlocks age/region-locked videos.
# Drop the file at ./server/cookies.txt and point here (./server mounts at /app).
YOUTUBE_COOKIES_FILE=

# Comma-separated yt-dlp player clients, e.g. "tv,web_safari". Empty = yt-dlp default.
YOUTUBE_PLAYER_CLIENTS=

# Explicit PO-token escape hatch ("<client>+<token>"). Usually unnecessary — the
# bundled bgutil sidecar supplies PO tokens automatically.
YOUTUBE_PO_TOKEN=

# bgutil PO-token provider URL. Defaults to the bundled sidecar.
YOUTUBE_POT_PROVIDER_URL=http://bgutil:4416
